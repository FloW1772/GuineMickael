---
import Layout from "../layouts/Layout.astro";
import TileDivider from "../components/TileDivider.astro";

// L'adresse email n'est PAS écrite en clair dans le HTML (anti-spam)
// Elle est encodée via le service Formspree — remplacer FORM_ID par l'ID réel
const FORMSPREE_ID = "YOUR_FORM_ID"; // TODO: remplacer par l'ID Formspree
---

<Layout
  title="Contact & devis gratuit"
  description="Demandez votre devis gratuit à Guiné Mickaël SARL — carreleur à Saint Pierre Montlimart. Contactez-nous par téléphone ou via le formulaire."
>
  <div class="page-hero">
    <div class="page-hero__inner">
      <p class="page-hero__label">Nous contacter</p>
      <h1 class="page-hero__title">Contact</h1>
    </div>
  </div>

  <TileDivider />

  <section class="section section--chalk">
    <div class="section__inner contact-grid">

      <!-- Coordonnées + carte de visite -->
      <div class="contact-info">
        <h2 class="contact-info__title">Coordonnées</h2>

        <address class="contact-address">
          <div class="contact-address__line">
            <span class="contact-address__icon" aria-hidden="true">📍</span>
            <span>21, Avenue du bordage<br />49110 Saint Pierre Montlimart</span>
          </div>
          <div class="contact-address__line">
            <span class="contact-address__icon" aria-hidden="true">📞</span>
            <div>
              <a href="tel:+33241751631" class="contact-address__link">02 41 75 16 31</a><br />
              <a href="tel:+33627323030" class="contact-address__link">06 27 32 30 30</a>
            </div>
          </div>
          <div class="contact-address__line">
            <span class="contact-address__icon" aria-hidden="true">🕐</span>
            <span>Lundi – Vendredi : 8h – 18h<br />Samedi : sur rendez-vous</span>
          </div>
        </address>

        <!-- Carte de visite — image originale -->
        <div class="business-card-embed reveal">
          <p class="business-card-embed__label">Notre carte de visite</p>
          <img
            src="/carte_de_visite.png"
            alt="Carte de visite SARL Guiné Mickaël — 21 Avenue du bordage, 49110 Saint Pierre Montlimart"
            class="business-card-embed__img"
            loading="lazy"
          />
        </div>

        <!-- Carte Google Maps (chargée au clic — RGPD) -->
        <div class="maps-wrapper reveal" id="maps-wrapper">
          <button class="maps-trigger" id="maps-trigger" aria-label="Afficher la carte Google Maps">
            <span>Afficher la carte</span>
            <span class="maps-trigger__sub">Un clic = chargement de Google Maps</span>
          </button>
          <iframe
            id="maps-iframe"
            class="maps-iframe"
            title="Localisation Guiné Mickaël SARL"
            loading="lazy"
            allowfullscreen
            hidden
          ></iframe>
        </div>
      </div>

      <!-- Formulaire de devis -->
      <div class="contact-form-wrapper" id="devis">
        <h2 class="form-title">Demander un devis gratuit</h2>
        <p class="form-subtitle">Réponse sous 48h en jours ouvrés.</p>

        <!-- Honeypot form anti-spam -->
        <form
          class="contact-form"
          id="contact-form"
          action={`https://formspree.io/f/${FORMSPREE_ID}`}
          method="POST"
          novalidate
        >
          <!-- Honeypot : champ caché, rempli seulement par les bots -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
          <input type="hidden" name="_subject" value="Nouveau devis — site guiné-mickael.fr" />

          <div class="form-group">
            <label for="name" class="form-label">Nom & prénom <span aria-hidden="true">*</span></label>
            <input
              type="text"
              id="name"
              name="name"
              class="form-input"
              required
              minlength="2"
              maxlength="100"
              autocomplete="name"
              aria-required="true"
            />
            <span class="form-error" id="name-error" role="alert" aria-live="polite"></span>
          </div>

          <div class="form-group">
            <label for="phone" class="form-label">Téléphone <span aria-hidden="true">*</span></label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="form-input"
              required
              autocomplete="tel"
              aria-required="true"
              pattern="[0-9\s\+\-\.]{8,20}"
            />
            <span class="form-error" id="phone-error" role="alert" aria-live="polite"></span>
          </div>

          <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              autocomplete="email"
              maxlength="200"
            />
            <span class="form-error" id="email-error" role="alert" aria-live="polite"></span>
          </div>

          <div class="form-group">
            <label for="project" class="form-label">Type de travaux <span aria-hidden="true">*</span></label>
            <select id="project" name="project" class="form-select" required aria-required="true">
              <option value="">Choisir…</option>
              <option value="carrelage-sol">Carrelage sol</option>
              <option value="carrelage-mur">Carrelage mur</option>
              <option value="douche-italienne">Douche à l'italienne</option>
              <option value="faience">Faïence</option>
              <option value="renovation">Rénovation complète</option>
              <option value="autre">Autre</option>
            </select>
            <span class="form-error" id="project-error" role="alert" aria-live="polite"></span>
          </div>

          <div class="form-group">
            <label for="message" class="form-label">Description du projet <span aria-hidden="true">*</span></label>
            <textarea
              id="message"
              name="message"
              class="form-textarea"
              rows="5"
              required
              minlength="20"
              maxlength="2000"
              aria-required="true"
              placeholder="Surface approximative, type de carrelage souhaité, délai envisagé…"
            ></textarea>
            <span class="form-error" id="message-error" role="alert" aria-live="polite"></span>
          </div>

          <button type="submit" class="form-submit" id="form-submit">
            Envoyer ma demande
          </button>

          <p class="form-mention">
            Vos données sont utilisées uniquement pour répondre à votre demande de devis.
            Aucune adresse email n'est stockée dans ce site.
          </p>
        </form>

        <div class="form-success" id="form-success" hidden>
          <p class="form-success__text">
            Votre demande a bien été envoyée. Nous vous répondrons sous 48h.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: var(--color-slate);
    padding: calc(72px + 4rem) clamp(1rem, 4vw, 3rem) 4rem;
  }

  .page-hero__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-hero__label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-ceramic);
    margin: 0 0 1rem;
  }

  .page-hero__title {
    font-size: var(--text-h1);
    color: var(--color-chalk);
    margin: 0;
  }

  .section { padding: var(--spacing-section) 0; }
  .section--chalk { background: var(--color-chalk); }

  .section__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 4vw, 3rem);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 769px) {
    .contact-grid {
      grid-template-columns: 1fr 1.5fr;
      gap: 5rem;
    }
  }

  /* Coordonnées */
  .contact-info__title {
    font-size: var(--text-h3);
    color: var(--color-slate);
    margin: 0 0 2rem;
  }

  .contact-address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  .contact-address__line {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-slate);
    opacity: 0.8;
  }

  .contact-address__icon { flex-shrink: 0; font-size: 1rem; }

  .contact-address__link {
    color: var(--color-ceramic);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .contact-address__link:hover { color: var(--color-navy); }

  /* Carte de visite — embed PDF */
  .business-card-embed {
    margin-bottom: 2rem;
  }

  .business-card-embed__label {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-orange);
    margin: 0 0 0.5rem;
  }

  .business-card-embed__img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid rgba(26, 26, 46, 0.08);
  }

  /* Google Maps RGPD */
  .maps-wrapper { position: relative; }

  .maps-trigger {
    width: 100%;
    padding: 1.5rem;
    background: rgba(26, 26, 46, 0.04);
    border: 1px dashed rgba(26, 26, 46, 0.2);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-slate);
    transition: background 0.2s ease;
  }

  .maps-trigger:hover { background: rgba(46, 159, 200, 0.08); }

  .maps-trigger__sub {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    opacity: 0.5;
  }

  .maps-iframe {
    width: 100%;
    height: 280px;
    border: none;
    display: block;
  }

  /* Formulaire */
  .form-title {
    font-size: var(--text-h2);
    color: var(--color-slate);
    margin: 0 0 0.5rem;
  }

  .form-subtitle {
    font-size: 0.875rem;
    color: var(--color-slate);
    opacity: 0.6;
    margin: 0 0 2.5rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-label {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-slate);
  }

  .form-label span {
    color: var(--color-orange);
  }

  .form-input,
  .form-select,
  .form-textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-slate);
    background: var(--color-chalk);
    border: 1.5px solid rgba(26, 26, 46, 0.2);
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color 0.2s ease;
    width: 100%;
    appearance: none;
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    border-color: var(--color-ceramic);
  }

  .form-input.is-error,
  .form-select.is-error,
  .form-textarea.is-error {
    border-color: #C0392B;
  }

  .form-textarea { resize: vertical; min-height: 120px; }

  .form-error {
    font-size: 0.75rem;
    color: #C0392B;
    min-height: 1rem;
  }

  .form-submit {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-chalk);
    background: var(--color-slate);
    border: none;
    padding: 1rem 2.5rem;
    cursor: pointer;
    align-self: flex-start;
    transition: background 0.2s ease;
  }

  .form-submit:hover,
  .form-submit:focus-visible {
    background: var(--color-orange);
  }

  .form-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .form-mention {
    font-size: 0.7rem;
    color: var(--color-slate);
    opacity: 0.45;
    margin: 0;
    line-height: 1.6;
  }

  .form-success {
    padding: 2rem;
    background: rgba(46, 159, 200, 0.1);
    border-left: 4px solid var(--color-ceramic);
  }

  .form-success__text {
    font-size: 0.95rem;
    color: var(--color-slate);
    margin: 0;
  }

</style>

<script>
  // Google Maps : chargement au clic (RGPD)
  const trigger = document.getElementById("maps-trigger");
  const iframe = document.getElementById("maps-iframe") as HTMLIFrameElement | null;

  if (trigger && iframe) {
    trigger.addEventListener("click", () => {
      iframe.src =
        "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2693.0!2d-1.0773!3d47.2987!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s21+Avenue+du+bordage+49110+Saint+Pierre+Montlimart!5e0!3m2!1sfr!2sfr!4v1700000000";
      iframe.removeAttribute("hidden");
      trigger.remove();
    });
  }

  // Formulaire : validation + anti-spam (délai minimum 3s)
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("form-submit") as HTMLButtonElement | null;
  const successDiv = document.getElementById("form-success");
  const formStart = Date.now();

  function showError(fieldId: string, msg: string) {
    const field = document.getElementById(fieldId);
    const error = document.getElementById(`${fieldId}-error`);
    field?.classList.add("is-error");
    if (error) error.textContent = msg;
  }

  function clearError(fieldId: string) {
    const field = document.getElementById(fieldId);
    const error = document.getElementById(`${fieldId}-error`);
    field?.classList.remove("is-error");
    if (error) error.textContent = "";
  }

  function validateForm(): boolean {
    let valid = true;
    const name = (document.getElementById("name") as HTMLInputElement).value.trim();
    const phone = (document.getElementById("phone") as HTMLInputElement).value.trim();
    const email = (document.getElementById("email") as HTMLInputElement).value.trim();
    const project = (document.getElementById("project") as HTMLSelectElement).value;
    const message = (document.getElementById("message") as HTMLTextAreaElement).value.trim();

    clearError("name"); clearError("phone"); clearError("email");
    clearError("project"); clearError("message");

    if (name.length < 2) { showError("name", "Veuillez indiquer votre nom."); valid = false; }
    if (!phone || !/[0-9]{8,}/.test(phone.replace(/\s/g, ""))) {
      showError("phone", "Numéro de téléphone invalide."); valid = false;
    }
    if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      showError("email", "Adresse email invalide."); valid = false;
    }
    if (!project) { showError("project", "Veuillez choisir un type de travaux."); valid = false; }
    if (message.length < 20) { showError("message", "Description trop courte (20 caractères minimum)."); valid = false; }

    return valid;
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!validateForm()) return;

    // Anti-spam : soumettre trop vite = bot probable
    if (Date.now() - formStart < 3000) return;

    submitBtn!.disabled = true;
    submitBtn!.textContent = "Envoi…";

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });

      if (res.ok) {
        form.hidden = true;
        successDiv?.removeAttribute("hidden");
      } else {
        submitBtn!.disabled = false;
        submitBtn!.textContent = "Envoyer ma demande";
        alert("Une erreur est survenue. Merci de nous appeler directement.");
      }
    } catch {
      submitBtn!.disabled = false;
      submitBtn!.textContent = "Envoyer ma demande";
      alert("Impossible d'envoyer le formulaire. Merci de nous appeler directement.");
    }
  });
</script>
