---
/**
 * Grille de galerie éditoriale auto-alimentée par import.meta.glob.
 * Chaque image est affichée avec un alt généré depuis son nom de fichier.
 */
import { Image } from "astro:assets";

interface ImageMeta {
  default: ImageMetadata;
}

type Category = {
  key: string;
  label: string;
  images: { src: ImageMetadata; alt: string; filename: string }[];
};

function filenameToAlt(filename: string): string {
  const prefixMap: Record<string, string> = {
    salon:    "Salon",
    sdb:      "Salle de bain",
    terrasse: "Terrasse",
  };
  const name = filename.replace(/\.[^.]+$/, ""); // retirer extension
  const parts = name.split("_");
  const prefix = parts[0];
  // Retirer le dernier segment s'il est purement numérique
  const middleParts = parts.slice(1).filter((p) => !/^\d+$/.test(p));
  const description = middleParts.join(" ").replace(/-/g, " ");
  const category = prefixMap[prefix] ?? prefix;
  return `${category} — ${description}`;
}

const salonImages = import.meta.glob<ImageMeta>(
  "../assets/images/realisations/salon/*.{jpg,jpeg,png,webp,avif}",
  { eager: true }
);

const sdbImages = import.meta.glob<ImageMeta>(
  "../assets/images/realisations/salle-de-bain/*.{jpg,jpeg,png,webp,avif}",
  { eager: true }
);

const terrasseImages = import.meta.glob<ImageMeta>(
  "../assets/images/realisations/terrasse/*.{jpg,jpeg,png,webp,avif}",
  { eager: true }
);

function toEntries(glob: Record<string, ImageMeta>) {
  return Object.entries(glob).map(([path, mod]) => ({
    src: mod.default,
    alt: filenameToAlt(path.split("/").pop()!),
    filename: path.split("/").pop()!,
  }));
}

const categories: Category[] = [
  { key: "salon",       label: "Salon",        images: toEntries(salonImages) },
  { key: "salle-de-bain", label: "Salle de bain", images: toEntries(sdbImages) },
  { key: "terrasse",    label: "Terrasse",     images: toEntries(terrasseImages) },
].filter((c) => c.images.length > 0);

interface Props {
  limit?: number; // si défini : mode aperçu (homepage)
  showFilters?: boolean;
}
const { limit, showFilters = false } = Astro.props;
---

{showFilters && categories.length > 1 && (
  <div class="gallery-filters" role="tablist" aria-label="Filtrer par catégorie">
    <button
      class="gallery-filter is-active"
      data-filter="all"
      role="tab"
      aria-selected="true"
    >
      Tout
      <span class="gallery-filter__count">
        {categories.reduce((acc, c) => acc + c.images.length, 0)}
      </span>
    </button>
    {categories.map((cat) => (
      <button
        class="gallery-filter"
        data-filter={cat.key}
        role="tab"
        aria-selected="false"
      >
        {cat.label}
        <span class="gallery-filter__count">{cat.images.length}</span>
      </button>
    ))}
  </div>
)}

<div class="gallery-grid" id="gallery-grid">
  {categories.flatMap((cat) =>
    (limit ? cat.images.slice(0, Math.ceil(limit / categories.length)) : cat.images).map(
      ({ src, alt, filename }, i) => (
        <figure
          class="gallery-item reveal"
          data-category={cat.key}
          data-index={i}
          style={`--i:${i}`}
        >
          <button
            class="gallery-item__btn"
            aria-label={`Agrandir : ${alt}`}
            data-lightbox-src={src.src}
            data-lightbox-alt={alt}
          >
            <Image
              src={src}
              alt={alt}
              widths={[400, 800, 1200]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              loading={i < 3 ? "eager" : "lazy"}
              class="gallery-item__img"
              quality={85}
            />
            <div class="gallery-item__overlay" aria-hidden="true">
              <span class="gallery-item__label">{cat.label}</span>
            </div>
          </button>
        </figure>
      )
    )
  )}
</div>

{showFilters && (
  <div
    class="lightbox"
    id="lightbox"
    role="dialog"
    aria-modal="true"
    aria-label="Vue agrandie"
    hidden
  >
    <button class="lightbox__close" id="lb-close" aria-label="Fermer">&#x2715;</button>
    <button class="lightbox__prev" id="lb-prev" aria-label="Image précédente">&#8592;</button>
    <button class="lightbox__next" id="lb-next" aria-label="Image suivante">&#8594;</button>
    <div class="lightbox__content">
      <img src="" alt="" class="lightbox__img" id="lb-img" />
      <p class="lightbox__caption" id="lb-caption"></p>
    </div>
  </div>
)}

<style>
  /* Filtres */
  .gallery-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .gallery-filter {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    border: 2px solid rgba(26, 26, 46, 0.15);
    background: transparent;
    color: var(--color-slate);
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, color 0.2s ease;
  }

  .gallery-filter:hover {
    border-color: var(--color-ceramic);
    color: var(--color-ceramic);
  }

  .gallery-filter.is-active {
    background: var(--color-slate);
    border-color: var(--color-slate);
    color: var(--color-chalk);
  }

  .gallery-filter__count {
    font-size: 0.7rem;
    opacity: 0.7;
  }

  /* Grille : 1 colonne mobile → 2 → 3 desktop */
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: 260px;
    gap: 12px;
  }

  @media (min-width: 481px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 200px;
    }

    .gallery-item:nth-child(1),
    .gallery-item:nth-child(5) {
      grid-column: span 2;
    }
  }

  @media (min-width: 769px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 280px;
    }

    .gallery-item:nth-child(1) {
      grid-column: span 2;
      grid-row: span 2;
    }

    .gallery-item:nth-child(5) {
      grid-column: span 2;
    }
  }

  .gallery-item {
    margin: 0;
    overflow: hidden;
    position: relative;
  }

  .gallery-item__btn {
    width: 100%;
    height: 100%;
    border: none;
    padding: 0;
    cursor: pointer;
    background: none;
    display: block;
    position: relative;
    overflow: hidden;
  }

  .gallery-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }

  .gallery-item__btn:hover .gallery-item__img,
  .gallery-item__btn:focus-visible .gallery-item__img {
    transform: scale(1.04);
  }

  .gallery-item__overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 46, 0);
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
    transition: background 0.35s ease;
  }

  .gallery-item__btn:hover .gallery-item__overlay,
  .gallery-item__btn:focus-visible .gallery-item__overlay {
    background: rgba(26, 26, 46, 0.45);
  }

  .gallery-item__label {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-chalk);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .gallery-item__btn:hover .gallery-item__label,
  .gallery-item__btn:focus-visible .gallery-item__label {
    opacity: 1;
    transform: translateY(0);
  }

  /* Items cachés par filtre */
  .gallery-item.is-hidden {
    display: none;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(10, 10, 20, 0.96);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox__content {
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .lightbox__img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
  }

  .lightbox__caption {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(248, 247, 244, 0.6);
    margin: 0;
  }

  .lightbox__close,
  .lightbox__prev,
  .lightbox__next {
    position: absolute;
    background: rgba(248, 247, 244, 0.1);
    border: 1px solid rgba(248, 247, 244, 0.2);
    color: var(--color-chalk);
    cursor: pointer;
    font-size: 1.25rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .lightbox__close:hover,
  .lightbox__prev:hover,
  .lightbox__next:hover {
    background: var(--color-ceramic);
  }

  .lightbox__close { top: 1.5rem; right: 1.5rem; }
  .lightbox__prev { left: 1.5rem; top: 50%; transform: translateY(-50%); }
  .lightbox__next { right: 1.5rem; top: 50%; transform: translateY(-50%); }

</style>

{showFilters && (
  <script>
    // Filtres
    const filters = document.querySelectorAll<HTMLButtonElement>(".gallery-filter");
    const items = document.querySelectorAll<HTMLElement>(".gallery-item");

    filters.forEach((btn) => {
      btn.addEventListener("click", () => {
        const filter = btn.dataset.filter!;
        filters.forEach((b) => {
          b.classList.toggle("is-active", b === btn);
          b.setAttribute("aria-selected", String(b === btn));
        });
        items.forEach((item) => {
          const show = filter === "all" || item.dataset.category === filter;
          item.classList.toggle("is-hidden", !show);
        });
      });
    });

    // Lightbox
    const lightbox = document.getElementById("lightbox")!;
    const lbImg = document.getElementById("lb-img") as HTMLImageElement;
    const lbCaption = document.getElementById("lb-caption")!;
    const lbClose = document.getElementById("lb-close")!;
    const lbPrev = document.getElementById("lb-prev")!;
    const lbNext = document.getElementById("lb-next")!;

    let allItems: HTMLButtonElement[] = [];
    let currentIndex = 0;

    function openLightbox(btn: HTMLButtonElement) {
      allItems = Array.from(
        document.querySelectorAll<HTMLButtonElement>(".gallery-item:not(.is-hidden) .gallery-item__btn")
      );
      currentIndex = allItems.indexOf(btn);
      showImage(currentIndex);
      lightbox.removeAttribute("hidden");
      document.body.style.overflow = "hidden";
      lbClose.focus();
    }

    function closeLightbox() {
      lightbox.setAttribute("hidden", "");
      document.body.style.overflow = "";
    }

    function showImage(idx: number) {
      const btn = allItems[idx];
      if (!btn) return;
      lbImg.src = btn.dataset.lightboxSrc!;
      lbImg.alt = btn.dataset.lightboxAlt!;
      lbCaption.textContent = btn.dataset.lightboxAlt!;
      currentIndex = idx;
    }

    document.querySelectorAll<HTMLButtonElement>(".gallery-item__btn").forEach((btn) => {
      btn.addEventListener("click", () => openLightbox(btn));
    });

    lbClose.addEventListener("click", closeLightbox);
    lbPrev.addEventListener("click", () =>
      showImage((currentIndex - 1 + allItems.length) % allItems.length)
    );
    lbNext.addEventListener("click", () =>
      showImage((currentIndex + 1) % allItems.length)
    );

    // Clic en dehors de l'image
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Clavier
    document.addEventListener("keydown", (e) => {
      if (lightbox.hasAttribute("hidden")) return;
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft") showImage((currentIndex - 1 + allItems.length) % allItems.length);
      if (e.key === "ArrowRight") showImage((currentIndex + 1) % allItems.length);
    });

    // Swipe mobile
    let touchStartX = 0;
    lightbox.addEventListener("touchstart", (e) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    lightbox.addEventListener("touchend", (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 50) {
        dx < 0
          ? showImage((currentIndex + 1) % allItems.length)
          : showImage((currentIndex - 1 + allItems.length) % allItems.length);
      }
    }, { passive: true });
  </script>
)}
